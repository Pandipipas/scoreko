{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.browser.tsbuildinfo",
  },
  "include": [
    "./src/browser_shared/**/*.ts",
    "./src/browser_shared/**/*.vue",
    "./src/dashboard/**/*.ts",
    "./src/dashboard/**/*.vue",
    "./src/graphics/**/*.ts",
    "./src/graphics/**/*.vue",
    "./src/types/**/*.d.ts"
  ]
}
