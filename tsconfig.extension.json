{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.extension.tsbuildinfo",
    "rootDir": "./src/extension",
    "outDir": "./extension",
    "verbatimModuleSyntax": true,
  },
  "include": [
    "./src/extension/**/*.ts",
    "./src/types/**/*.d.ts"
  ],
  "exclude": [
    "./src/types/augment-window.d.ts"
  ]
}
