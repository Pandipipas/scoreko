{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "scoreboardSkin": {
      "type": "string",
      "default": "opeik-runback"
    },
    "commentarySkin": {
      "type": "string",
      "default": "opeik-commentary"
    },
    "locale": {
      "type": "string",
      "enum": ["en", "es"],
      "default": "en"
    }
  },
  "required": ["scoreboardSkin", "commentarySkin", "locale"],
  "default": {
    "scoreboardSkin": "opeik-runback",
    "commentarySkin": "opeik-commentary",
    "locale": "en"
  }
}
